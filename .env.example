# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sankara_eyebank

# Session secret — use a long random string in production
SESSION_SECRET=change-me-to-a-secure-random-secret

# JWT secret — use a long random string in production
JWT_SECRET=change-me-to-another-secure-random-secret

# Server
NODE_ENV=development
PORT=8080
